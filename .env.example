# Proxies.rent Dashboard — Environment Variables
# Copy to .env and fill in values

# Server
PORT=3000

# ProxySmart API servers
API_S1_URL=http://YOUR_S1_IP:7002
API_S1_USER=proxy
API_S1_PASS=your_s1_password
API_S1_PUBLIC_IP=YOUR_S1_PUBLIC_IP
API_S1_COUNTRY=MD
API_S1_COUNTRY_NAME=Moldova
API_S1_TZ=Europe/Chisinau

API_S2_URL=http://YOUR_S2_IP:8080
API_S2_USER=proxy
API_S2_PASS=your_s2_password
API_S2_PUBLIC_IP=YOUR_S2_PUBLIC_IP
API_S2_COUNTRY=RO
API_S2_COUNTRY_NAME=Romania
API_S2_TZ=Europe/Bucharest

# Tochka Bank API
TOCHKA_JWT=your_tochka_jwt_token
TOCHKA_CLIENT_ID=your_tochka_client_id
TOCHKA_ACCOUNT=your_tochka_account
TOCHKA_WEBHOOK_SECRET=your_webhook_secret

# CRM (Twenty CRM)
CRM_URL=https://your-crm-domain.com
CRM_EMAIL=admin@yourdomain.com
CRM_PASSWORD=your_crm_password
CRM_DB_URL=postgresql://user:password@host:5432/dbname
CRM_WORKSPACE=your_workspace_id

# Admin credentials (format: USER_<login>=<password>|<portNameFilter>)
# Use * for admin access to all ports
USER_admin=your_strong_admin_password|*
